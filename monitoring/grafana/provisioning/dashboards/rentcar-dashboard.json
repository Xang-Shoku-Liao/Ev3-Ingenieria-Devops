  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🚗 RentCar — Estado General",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "textMode": "auto" },
      "title": "Estado del Servicio",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "up{job=\"rentcar-api\"}",
          "legendFormat": "Estado"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center" },
      "title": "CPU del Proceso",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "process_cpu_usage{application=\"rentacar\"}",
          "legendFormat": "CPU"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 400000000 },
              { "color": "red", "value": 700000000 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center" },
      "title": "Memoria JVM Usada",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "jvm_memory_used_bytes{application=\"rentacar\", area=\"heap\"}",
          "legendFormat": "Heap"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "title": "Errores HTTP (5xx) últimos 5 min",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(http_server_requests_seconds_count{application=\"rentacar\", status=~\"5..\"}[5m])) or vector(0)",
          "legendFormat": "Errores 5xx"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center" },
      "title": "Tiempo de Respuesta Promedio",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_server_requests_seconds_sum{application=\"rentacar\"}[5m]) / rate(http_server_requests_seconds_count{application=\"rentacar\"}[5m])",
          "legendFormat": "Avg Response"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "📊 Métricas de Tráfico HTTP",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 6,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Tasa de Solicitudes por Endpoint",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_server_requests_seconds_count{application=\"rentacar\"}[5m])",
          "legendFormat": "{{method}} {{uri}} ({{status}})"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 7,
      "title": "Latencia P95 por Endpoint",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{application=\"rentacar\"}[5m]))",
          "legendFormat": "p95 {{uri}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "🧠 Recursos JVM",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 8,
      "title": "Uso de Memoria JVM (Heap vs Non-Heap)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "jvm_memory_used_bytes{application=\"rentacar\", area=\"heap\"}",
          "legendFormat": "Heap Usado"
        },
        {
          "datasource": "Prometheus",
          "expr": "jvm_memory_max_bytes{application=\"rentacar\", area=\"heap\"}",
          "legendFormat": "Heap Máximo"
        },
        {
          "datasource": "Prometheus",
          "expr": "jvm_memory_used_bytes{application=\"rentacar\", area=\"nonheap\"}",
          "legendFormat": "Non-Heap Usado"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 9,
      "title": "Threads JVM Activos",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "jvm_threads_live_threads{application=\"rentacar\"}",
          "legendFormat": "Threads Activos"
        },
        {
          "datasource": "Prometheus",
          "expr": "jvm_threads_daemon_threads{application=\"rentacar\"}",
          "legendFormat": "Threads Daemon"
        }
      ]
    }
  ],
  "refresh": "30s",
